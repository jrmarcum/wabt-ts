{
  "name": "@wasmtk/wabt-ts",
  "version": "0.1.0",
  "exports": {
    ".": "./src/index.ts",
    "./wat2wasm": "./src/tools/wat2wasm.ts",
    "./wasm2wat": "./src/tools/wasm2wat.ts",
    "./wasm-validate": "./src/tools/wasm-validate.ts",
    "./wasm-objdump": "./src/tools/wasm-objdump.ts",
    "./wasm2ts": "./src/tools/wasm2ts.ts"
  },

  "tasks": {
    "check": "deno check src/**/*.ts tests/**/*.ts",
    "test": "deno test --allow-read tests/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },

  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0"
  },

  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "lib": ["ES2022", "deno.ns"]
  },

  "lint": {
    "include": ["src/", "tests/"],
    "rules": {
      "tags": ["recommended"]
    }
  },

  "fmt": {
    "include": ["src/", "tests/"],
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true
  },

  "exclude": ["upstream/", "dist/", "node_modules/"]
}
